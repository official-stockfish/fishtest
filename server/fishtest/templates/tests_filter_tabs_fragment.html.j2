{% set filters = filters if filters is defined else {} %}
{% set hx_target = hx_target if hx_target is defined else '' %}
{% set base_url = base_url if base_url is defined else '/tests/finished' %}
{% set success_only = filters.success_only | default(false) %}
{% set yellow_only = filters.yellow_only | default(false) %}
{% set ltc_only = filters.ltc_only | default(false) %}
{% set all_query_string = filters.all_query_string | default('') %}
{% set green_query_string = filters.green_query_string | default('?success_only=1' ~ (filters.filtered_query_suffix | default(''))) %}
{% set yellow_query_string = filters.yellow_query_string | default('?yellow_only=1' ~ (filters.filtered_query_suffix | default(''))) %}
{% set ltc_query_string = filters.ltc_query_string | default('?ltc_only=1' ~ (filters.filtered_query_suffix | default(''))) %}

{% set all_url = base_url ~ all_query_string %}
{% set greens_url = base_url ~ green_query_string %}
{% set yellows_url = base_url ~ yellow_query_string %}
{% set ltc_url = base_url ~ ltc_query_string %}

<a class="btn btn-sm btn-light border tests-filter-tab {{ 'active' if not success_only and not yellow_only and not ltc_only else '' }}" href="{{ all_url }}" hx-get="{{ all_url }}" hx-target="#{{ hx_target }}" hx-push-url="true" hx-swap="innerHTML">All</a>
<a class="btn btn-sm btn-light border tests-filter-tab {{ 'active' if success_only else '' }}" href="{{ greens_url }}" hx-get="{{ greens_url }}" hx-target="#{{ hx_target }}" hx-push-url="true" hx-swap="innerHTML">Green</a>
<a class="btn btn-sm btn-light border tests-filter-tab {{ 'active' if yellow_only else '' }}" href="{{ yellows_url }}" hx-get="{{ yellows_url }}" hx-target="#{{ hx_target }}" hx-push-url="true" hx-swap="innerHTML">Yellow</a>
<a class="btn btn-sm btn-light border tests-filter-tab {{ 'active' if ltc_only else '' }}" href="{{ ltc_url }}" hx-get="{{ ltc_url }}" hx-target="#{{ hx_target }}" hx-push-url="true" hx-swap="innerHTML">LTC</a>
