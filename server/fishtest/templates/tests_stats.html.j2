{% extends "base.html.j2" %}

{% block title %}Statistics - {{ page_title }} | Stockfish Testing{% endblock %}

{% block body %}
{% set run_id = stats.run_id %}
{% set has_spsa = stats.has_spsa %}

{% if not has_spsa and not run.get("finished", false) %}
  <div
    hx-get="/tests/stats/{{ run_id }}"
    hx-trigger="every {{ poll.tests_stats }}s [document.visibilityState === 'visible'], visibilitychange[document.visibilityState === 'visible'] from:document"
    hx-target="#tests-stats-content"
    hx-swap="outerHTML"
  ></div>
{% endif %}

{% include "tests_stats_content_fragment.html.j2" %}
{% endblock %}
