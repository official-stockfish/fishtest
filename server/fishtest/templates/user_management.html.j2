{% extends "base.html.j2" %}

{% block title %}User Management | Stockfish Testing{% endblock %}

{% block body %}
<h2>User Management</h2>

<div class="mw-xxl">
  <div class="row g-3 mb-3">
    <div class="col-6 col-sm">
      <div class="card card-lg-sm text-center">
        <div class="card-header text-nowrap" title="All Users">All</div>
        <div class="card-body">
          <h4 class="card-title mb-0 monospace">{{ all_count }}</h4>
        </div>
      </div>
    </div>
    <div class="col-6 col-sm">
      <div class="card card-lg-sm text-center">
        <div class="card-header text-nowrap" title="Pending Users">Pending</div>
        <div class="card-body">
          <h4 class="card-title mb-0 monospace">{{ pending_count }}</h4>
        </div>
      </div>
    </div>
    <div class="col-6 col-sm">
      <div class="card card-lg-sm text-center">
        <div class="card-header text-nowrap" title="Blocked users">Blocked</div>
        <div class="card-body">
          <h4 class="card-title mb-0 monospace">{{ blocked_count }}</h4>
        </div>
      </div>
    </div>
    <div class="col-6 col-sm">
      <div class="card card-lg-sm text-center">
        <div class="card-header text-nowrap" title="Idle Users">Idle</div>
        <div class="card-body">
          <h4 class="card-title mb-0 monospace">{{ idle_count }}</h4>
        </div>
      </div>
    </div>
    <div class="col-6 col-sm">
      <div class="card card-lg-sm text-center">
        <div class="card-header text-nowrap" title="Approver Users">Approvers</div>
        <div class="card-body">
          <h4 class="card-title mb-0 monospace">{{ approvers_count }}</h4>
        </div>
      </div>
    </div>
  </div>
</div>

<form
  id="user-management-filters"
  class="row g-3 mb-3 align-items-end"
  method="get"
  action="/user_management"
  hx-get="/user_management"
  hx-target="#user-management-content"
  hx-push-url="true"
  hx-swap="innerHTML"
  hx-trigger="submit, input changed delay:{{ htmx.input_changed_delay_ms }}ms from:#user_management_q, search from:#user_management_q, change from:#user_management_group"
>
  <input type="hidden" name="sort" value="{{ sort }}">
  <input type="hidden" name="order" value="{{ order }}">
  <input type="hidden" name="view" value="{{ view }}">

  <div class="col-12 col-md-auto">
    <label for="user_management_group" class="form-label">Group</label>
    <select id="user_management_group" class="form-select" name="group">
      <option value="all" {{ 'selected' if group == 'all' else '' }}>All</option>
      <option value="pending" {{ 'selected' if group == 'pending' else '' }}>Pending</option>
      <option value="blocked" {{ 'selected' if group == 'blocked' else '' }}>Blocked</option>
      <option value="idle" {{ 'selected' if group == 'idle' else '' }}>Idle</option>
      <option value="approvers" {{ 'selected' if group == 'approvers' else '' }}>Approvers</option>
    </select>
  </div>

  <div class="col-12 col-md-auto">
    <label for="user_management_q" class="form-label">Filter username</label>
    <input
      id="user_management_q"
      type="search"
      name="q"
      class="form-control"
      value="{{ q }}"
      placeholder="Filter username"
      autocomplete="off"
    >
  </div>
</form>

<div id="user-management-content">
  {% include "user_management_content_fragment.html.j2" %}
</div>
{% endblock %}
