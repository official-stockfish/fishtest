{% extends "base.html.j2" %}

{% set is_monthly = is_monthly if is_monthly is defined else false %}
{% set monthly_suffix = monthly_suffix if monthly_suffix is defined else "" %}

{% block title %}Contributors{{ monthly_suffix }} | Stockfish Testing{% endblock %}

{% block body %}
<h2> Contributors{{ monthly_suffix }} </h2>

<div class="row g-3 mb-3">
  <div class="col-6 col-sm">
    <div class="card card-lg-sm text-center">
      <div class="card-header text-nowrap" title="Testers">Testers</div>
      <div class="card-body">
        <h4 class="card-title mb-0 monospace">
          {{ summary.testers }}
        </h4>
      </div>
    </div>
  </div>

  <div class="col-6 col-sm">
    <div class="card card-lg-sm text-center">
      <div class="card-header text-nowrap" title="Developers">Developers</div>
      <div class="card-body">
        <h4 class="card-title mb-0 monospace">
          {{ summary.developers }}
        </h4>
      </div>
    </div>
  </div>

  <div class="col-6 col-sm">
    <div class="card card-lg-sm text-center">
      <div class="card-header text-nowrap" title="Active testers">Active testers</div>
      <div class="card-body">
        <h4 class="card-title mb-0 monospace">
          {{ summary.active_testers }}
        </h4>
      </div>
    </div>
  </div>

  <div class="col-6 col-sm">
    <div class="card card-lg-sm text-center">
      <div class="card-header text-nowrap" title="CPU years">CPU years</div>
      <div class="card-body">
        <h4 class="card-title mb-0 monospace">
          {{ "{0:.2f}".format(summary.cpu_hours / (24 * 365)) }}
        </h4>
      </div>
    </div>
  </div>

  <div class="col-6 col-sm">
    <div class="card card-lg-sm text-center">
      <div class="card-header text-nowrap" title="Games played">Games played</div>
      <div class="card-body">
        <h4 class="card-title mb-0 monospace">
          {{ summary.games }}
        </h4>
      </div>
    </div>
  </div>

  <div class="col-6 col-sm">
    <div class="card card-lg-sm text-center">
      <div class="card-header text-nowrap" title="Tests submitted">Tests submitted</div>
      <div class="card-body">
        <h4 class="card-title mb-0 monospace">
          {{ summary.tests }}
        </h4>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-1 align-items-end">
  <div class="col-12 col-md-auto">
    <form method="GET" action="{{ request.url.path }}">
      <label for="search_contributors" class="form-label">Search</label>
      <div class="d-flex align-items-center gap-2">
        <input
          id="search_contributors"
          class="form-control"
          placeholder="Search username"
          type="search"
          name="search"
          value="{{ search }}"
        >
        <button type="submit" class="btn btn-secondary">Search</button>
      </div>
      <div class="form-text">Typing filters current page instantly. Use Search for full contributors DB query.</div>
    </form>
  </div>
</div>

{% include "pagination.html.j2" %}

<div class="table-responsive-lg">
  <table id="contributors_table" class="table table-striped table-sm">
    <thead class="sticky-top">
      <tr>
        <th></th>
        <th>Username</th>
        <th class="text-end">Last active</th>
        <th class="text-end">Games/Hour</th>
        <th class="text-end">CPU Hours</th>
        <th class="text-end">Games played</th>
        <th class="text-end">Tests submitted</th>
        <th>Tests repository</th>
      </tr>
    </thead>
    <tbody>
      {% include "contributors_rows_fragment.html.j2" %}
    </tbody>
  </table>
</div>

{% include "pagination.html.j2" %}

<script>
  (() => {
    const searchInput = document.getElementById("search_contributors");
    const tableBody = document.querySelector("#contributors_table tbody");
    if (!searchInput || !tableBody) {
      return;
    }

    const rows = Array.from(
      tableBody.querySelectorAll('tr[data-contributor-row="true"]'),
    );
    const emptyRows = Array.from(tableBody.querySelectorAll('tr[data-empty-row="true"]'));

    // Keep static no-data rows hidden while local filtering is active.
    emptyRows.forEach((row) => row.classList.add("d-none"));

    const noMatchRow = document.createElement("tr");
    noMatchRow.classList.add("d-none");
    noMatchRow.setAttribute("data-no-match-row", "true");
    const noMatchCell = document.createElement("td");
    noMatchCell.colSpan = 20;
    noMatchCell.textContent = "No matching users";
    noMatchRow.append(noMatchCell);
    tableBody.append(noMatchRow);

    const applyFilter = () => {
      const query = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      for (const row of rows) {
        const username = row.dataset.username || "";
        const isVisible = query === "" || username.includes(query);
        row.classList.toggle("d-none", !isVisible);
        if (isVisible) {
          visibleCount += 1;
        }
      }

      noMatchRow.classList.toggle("d-none", visibleCount > 0);
    };

    searchInput.addEventListener("input", applyFilter);
    applyFilter();
  })();
</script>

{% endblock %}
