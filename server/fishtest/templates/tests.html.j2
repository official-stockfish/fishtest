{% extends "base.html.j2" %}

{% block body %}
<link
  rel="stylesheet"
  href="{{ static_url('fishtest:static/css/flags.css') }}"
>

<h2>Stockfish Testing Queue</h2>

{% if page_idx == 0 %}
  {% set machines_sort = machines_sort if machines_sort is defined else "last_active" %}
  {% set machines_order = machines_order if machines_order is defined else "desc" %}
  {% set machines_q = machines_q if machines_q is defined else "" %}
  {% set machines_page = machines_page if machines_page is defined else 1 %}
  {% set machines_my_workers = machines_my_workers if machines_my_workers is defined else false %}
  {% set has_authenticated_user = has_authenticated_user if has_authenticated_user is defined else false %}

  <div class="mw-xxl">
    <div id="homepage-stats">
      {% include "homepage_stats_fragment.html.j2" %}
    </div>
  </div>

  <h4>
    <a id="machines-button" class="btn btn-sm btn-light border"
      data-toggle-cookie-max-age="{{ cookies.panel_toggle_max_age }}"
      data-bs-toggle="collapse" href="#machines-panel" role="button" aria-expanded="{{ 'true' if machines_shown else 'false' }}"
      aria-controls="machines-panel">
      {{ 'Hide' if machines_shown else 'Show' }}
    </a>
    <span id="workers-count">
      {{ workers_count_text if workers_count_text is defined else ("Workers - " ~ machines_count ~ " machines") }}
    </span>
  </h4>

  <section id="machines-panel" class="collapse {{ 'show' if machines_shown else '' }}">
    <form
      class="row g-2 align-items-end mb-2"
      id="machines-filters"
      action="/tests/machines"
      hx-get="/tests/machines"
      hx-target="#machines"
      hx-swap="innerHTML"
      hx-trigger="submit, input changed delay:{{ htmx.input_changed_delay_ms }}ms from:#machines_q{% if has_authenticated_user %}, change from:#machines_my_workers{% endif %}"
    >
      <input type="hidden" id="machines_sort" name="sort" value="{{ machines_sort }}">
      <input type="hidden" id="machines_order" name="order" value="{{ machines_order }}">
      <input type="hidden" id="machines_page" name="page" value="{{ machines_page }}">

      <div class="col-auto">
        <input
          class="form-control form-control-sm"
          type="search"
          id="machines_q"
          name="q"
          value="{{ machines_q }}"
          placeholder="Filter any column"
          aria-label="Filter any column"
          autocomplete="off"
        >
      </div>

      {% if has_authenticated_user %}
        <div class="col-auto">
          <div class="form-check mb-1">
            <input
              class="form-check-input"
              type="checkbox"
              value="1"
              id="machines_my_workers"
              name="my_workers"
              {{ 'checked' if machines_my_workers else '' }}
            >
            <label class="form-check-label" for="machines_my_workers">My workers</label>
          </div>
        </div>
      {% endif %}

      <div class="col-auto" id="machines-pagination" aria-live="polite"></div>
    </form>
  {% set height = (machines_count * 37) | string ~ "px" %}
    <section id="machines"
      data-machines-loaded="0"
      class="overflow-auto machines-panel-scroll"
      hx-get="/tests/machines"
      hx-include="#machines-filters"
      hx-sync="#machines-filters:abort"
      hx-trigger="{% if machines_shown %}load, {% endif %}machines:load, every {{ poll.machines_homepage }}s [document.visibilityState === 'visible' && document.getElementById('machines-panel').classList.contains('show') && document.activeElement?.id !== 'machines_q'], visibilitychange[document.visibilityState === 'visible' && document.getElementById('machines-panel').classList.contains('show') && document.activeElement?.id !== 'machines_q'] from:document"
      hx-swap="innerHTML"
      >
      <div id="machines-loading" class="skeleton-wrap">
        <div class="skeleton-line"></div>
        <div
          class="skeleton-block machines-skeleton-block"
          style="--machines-skeleton-height: {{ height }};">
          </div>
      </div>
    </section>
  </section>
  <script src="{{ static_url('fishtest:static/js/tests_homepage.js') }}"></script>
{% endif %}

{% if run_tables_ctx is defined %}
  {% with
    pending_approval_runs=run_tables_ctx.pending_approval_runs,
    paused_runs=run_tables_ctx.paused_runs,
    active_runs=run_tables_ctx.active_runs,
    failed_runs=run_tables_ctx.failed_runs,
    finished_runs=run_tables_ctx.finished_runs,
    num_finished_runs=run_tables_ctx.num_finished_runs,
    finished_runs_pages=run_tables_ctx.finished_runs_pages,
    page_idx=run_tables_ctx.page_idx,
    prefix=run_tables_ctx.prefix,
    toggle_states=run_tables_ctx.toggle_states,
    finished_title_text=run_tables_ctx.finished_title_text,
    show_gauge=run_tables_ctx.show_gauge
  %}
    {% include "run_tables.html.j2" %}
  {% endwith %}
{% else %}
  {% include "run_tables.html.j2" %}
{% endif %}
{% endblock %}
