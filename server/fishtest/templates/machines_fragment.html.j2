{% set pagination_hx_target = "machines" %}
{% set pagination_hx_push_url = false %}
{% set pagination_hx_sync = "#machines-filters:abort" %}
{% set pagination_hx_disinherit = "hx-include" %}
{% set pagination_hx_params = "none" %}
{% set sort = sort if sort is defined else "last_active" %}
{% set order = order if order is defined else "desc" %}
{% set q = q if q is defined else "" %}
{% set current_page = current_page if current_page is defined else 1 %}
{% set my_workers = my_workers if my_workers is defined else false %}
{% set pages = pages if pages is defined else [] %}

{% macro sort_header(field, label) -%}
  {% set is_active = (sort == field) %}
  {% set next_order = "desc" if (is_active and order == "asc") else "asc" %}
  <th{% if is_active %} aria-sort="{{ 'ascending' if order == 'asc' else 'descending' }}"{% endif %}>
    <a
      class="sort-header text-decoration-none text-reset d-inline-flex align-items-center gap-1"
      href="/tests/machines?sort={{ field }}&order={{ next_order }}{% if q %}&q={{ q | urlencode }}{% endif %}{% if my_workers %}&my_workers=1{% endif %}"
      hx-get="/tests/machines?sort={{ field }}&order={{ next_order }}{% if q %}&q={{ q | urlencode }}{% endif %}{% if my_workers %}&my_workers=1{% endif %}"
      hx-target="#machines"
      hx-swap="innerHTML"
      hx-sync="#machines-filters:abort"
      hx-disinherit="hx-include"
      hx-params="none"
    >
      <span>{{ label }}</span>
      <span class="sort-indicator" aria-hidden="true">{% if is_active and order == "asc" %}▲{% elif is_active and order == "desc" %}▼{% else %}↕{% endif %}</span>
    </a>
  </th>
{%- endmacro %}

<template>
  <div id="machines-pagination" class="d-flex align-items-end" hx-swap-oob="innerHTML">
    {% with pages=pages %}
      {% include "pagination.html.j2" %}
    {% endwith %}
  </div>
</template>

  <table id="machines_table" class="table table-striped table-sm">
  <thead class="sticky-top">
    <tr>
      {{ sort_header("machine", "Machine") }}
      {{ sort_header("cores", "Cores") }}
      {{ sort_header("uuid", "UUID") }}
      {{ sort_header("mnps", "MNps") }}
      {{ sort_header("ram", "RAM") }}
      {{ sort_header("system", "System") }}
      {{ sort_header("arch", "Arch") }}
      {{ sort_header("compiler", "Compiler") }}
      {{ sort_header("python", "Python") }}
      {{ sort_header("worker", "Worker") }}
      {{ sort_header("running_on", "Running on") }}
      {{ sort_header("last_active", "Last active") }}
    </tr>
  </thead>
  <tbody>
    {% for machine in machines %}
      {% set country_code = machine.country_code if machine.country_code is defined else "" %}
      {% set worker_url = machine.worker_url %}
      {% set worker_short = machine.worker_short %}
      {% set run_url = machine.run_url %}
      {% set run_label = machine.run_label %}
      <tr>
        <td>{{ machine.username }}</td>
        <td>
          {% if country_code %}
            <div class="flag flag-{{ country_code | lower }}"></div>
          {% endif %}
          {{ machine.concurrency }}
        </td>
        <td><a href="{{ worker_url }}">{{ worker_short }}</a></td>
        <td>{{ machine.nps_m }}</td>
        <td>{{ machine.max_memory }}</td>
        <td>{{ machine.system }}</td>
        <td>{{ machine.worker_arch }}</td>
        <td>{{ machine.compiler_label }}</td>
        <td>{{ machine.python_label }}</td>
        <td>{{ machine.version_label }}</td>
        <td>
          <a href="{{ run_url }}" title="{{ run_label }}">{{ run_label }}</a>
        </td>
        <td data-sort-value="{{ machine.last_active_sort }}">{{ machine.last_active_label }}</td>
      </tr>
    {% else %}
      <tr id="no-machines">
        <td colspan=20>No machines running</td>
      </tr>
    {% endfor %}
  </tbody>
</table>

<input type="hidden" id="machines_sort" name="sort" value="{{ sort }}" hx-swap-oob="true">
<input type="hidden" id="machines_order" name="order" value="{{ order }}" hx-swap-oob="true">
<input type="hidden" id="machines_page" name="page" value="{{ current_page }}" hx-swap-oob="true">

<span id="workers-count" hx-swap-oob="innerHTML">
  {{ workers_count_text if workers_count_text is defined else ("Workers - " ~ machines_count ~ " machines") }}
</span>
